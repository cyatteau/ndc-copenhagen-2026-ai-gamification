      async function arcgisJson(url) {
        const response = await fetch(url)
        if (!response.ok) throw new Error(`ArcGIS returned ${response.status}`)
        return response.json()
      }

      function buildArcgisUrl(path, params = {}) {
        const url = new URL(
          `https://geocode-api.arcgis.com/arcgis/rest/services/World/GeocodeServer/${path}`
        )
        url.searchParams.set('f', 'json')
        url.searchParams.set('token', CONFIG.arcgisApiKey)

        Object.entries(params).forEach(([key, value]) => {
          if (value != null && value !== '') url.searchParams.set(key, value)
        })

        return url
      }

      function renderLocationSuggestions(items) {
        suggestionsDropdownEl.innerHTML = ''

        if (!items.length) {
          locationInput.setAttribute('aria-expanded', 'false')
          suggestionsDropdownEl.classList.add('hidden')
          return
        }

        items.forEach(item => {
          const li = document.createElement('li')
          li.textContent = item.text
          li.className = 'suggestion-item'
          li.setAttribute('role', 'option')

          li.addEventListener('click', () => {
            locationInput.value = item.text
            selectedSuggestion = item
            document
              .querySelectorAll('.suggestion-item')
              .forEach(el => el.classList.remove('active'))
            li.classList.add('active')
            suggestionsDropdownEl.classList.add('hidden')
            locationInput.setAttribute('aria-expanded', 'false')
            statusEl.textContent = `Selected place: ${item.text}`
          })

          suggestionsDropdownEl.appendChild(li)
