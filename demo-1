      async function fetchLocationSuggestions() {
        const text = locationInput.value.trim()

        if (selectedSuggestion && selectedSuggestion.text !== text) {
          selectedSuggestion = null
        }

        if (text.length < 3) {
          locationInput.setAttribute('aria-expanded', 'false')
          suggestionsDropdownEl.classList.add('hidden')
          return
        }

        try {
          const url = buildArcgisUrl('suggest', {
            text,
            maxSuggestions: '5',
            location:
              lastKnownCoords?.lat != null && lastKnownCoords?.lon != null
                ? `${lastKnownCoords.lon},${lastKnownCoords.lat}`
                : null
          })

          const data = await arcgisJson(url)
          renderLocationSuggestions(
            (data.suggestions || []).map(item => ({
              text: item.text,
              magicKey: item.magicKey
            }))
          )
        } catch (err) {
          console.error('suggest error:', err)
          suggestionsDropdownEl.classList.add('hidden')
        }
      }

      async function resolveSelectedPlace() {
        if (!selectedSuggestion) return null

        const url = buildArcgisUrl('findAddressCandidates', {
          SingleLine: selectedSuggestion.text,
          magicKey: selectedSuggestion.magicKey,
          maxLocations: '1'
        })

        const data = await arcgisJson(url)
        const candidate = data.candidates?.[0]

        if (!candidate) {
          return { ok: true, found: false }
        }

        return {
          ok: true,
          found: true,
          label: candidate.address,
          location: candidate.location,
          score: candidate.score
        }
      }

      async function reverseGeocode(lat, lon) {
        const url = buildArcgisUrl('reverseGeocode', {
          location: `${lon},${lat}`
        })

        const data = await arcgisJson(url)

        return {
          label:
            data.address?.LongLabel ||
            data.address?.Match_addr ||
            'Current location',
          address: data.address || null,
          location: data.location || null
        }
      }

