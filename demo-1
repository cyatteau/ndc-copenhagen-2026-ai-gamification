      async function postOpenAIJson(payload) {
        const response = await fetch('https://api.openai.com/v1/responses', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Authorization: `Bearer ${CONFIG.openaiApiKey}`
          },
          body: JSON.stringify(payload)
        })

        const rawText = await response.text()
        let json = {}

        if (rawText) {
          try {
            json = JSON.parse(rawText)
          } catch (error) {
            if (!response.ok) {
              throw new Error(rawText || `OpenAI returned ${response.status}`)
            }
            throw new Error('OpenAI returned a non-JSON response.')
          }
        }

        if (!response.ok) {
          throw new Error(
            json?.error?.message ||
              json?.message ||
              rawText ||
              `OpenAI returned ${response.status}`
          )
        }

        return json
      }

      function extractOutputText(responseJson) {
        if (
          typeof responseJson?.output_text === 'string' &&
          responseJson.output_text.trim()
        ) {
          return responseJson.output_text.trim()
        }

        const chunks = []
        const outputs = responseJson?.output || []

        for (const item of outputs) {
          for (const content of item?.content || []) {
            if (typeof content?.text === 'string' && content.text.trim()) {
              chunks.push(content.text.trim())
            }
            if (
              typeof content?.output_text === 'string' &&
              content.output_text.trim()
            ) {
              chunks.push(content.output_text.trim())
            }
            if (typeof content?.value === 'string' && content.value.trim()) {
              chunks.push(content.value.trim())
            }
            if (typeof content?.json === 'string' && content.json.trim()) {
              chunks.push(content.json.trim())
            }
            if (
              typeof content?.arguments === 'string' &&
              content.arguments.trim()
            ) {
              chunks.push(content.arguments.trim())
            }
          }
        }

        return chunks.join('\n').trim()
      }

      function extractFirstJsonObject(text) {
        if (!text) return null

        const trimmed = String(text).trim()

        try {
          return JSON.parse(trimmed)
        } catch {}

        const fenceMatch = trimmed.match(/```(?:json)?\s*([\s\S]*?)```/i)
        if (fenceMatch?.[1]) {
          try {
            return JSON.parse(fenceMatch[1].trim())
          } catch {}
        }

        const start = trimmed.indexOf('{')
        const end = trimmed.lastIndexOf('}')
        if (start !== -1 && end !== -1 && end > start) {
          try {
            return JSON.parse(trimmed.slice(start, end + 1))
          } catch {}
        }

        return null
      }

      function extractStructuredObject(responseJson) {
        if (
          responseJson?.output_parsed &&
          typeof responseJson.output_parsed === 'object'
        ) {
          return responseJson.output_parsed
        }

        const outputs = responseJson?.output || []

        for (const item of outputs) {
          if (item?.parsed && typeof item.parsed === 'object') {
            return item.parsed
          }

          for (const content of item?.content || []) {
            if (content?.parsed && typeof content.parsed === 'object') {
              return content.parsed
            }

            if (content?.json && typeof content.json === 'string') {
              const parsedJson = extractFirstJsonObject(content.json)
              if (parsedJson) return parsedJson
            }

            if (
              content?.arguments &&
              typeof content.arguments === 'string'
            ) {
              const parsedArgs = extractFirstJsonObject(content.arguments)
              if (parsedArgs) return parsedArgs
            }

            if (content?.text && typeof content.text === 'string') {
              const parsedText = extractFirstJsonObject(content.text)
              if (parsedText) return parsedText
            }

            if (
              content?.output_text &&
              typeof content.output_text === 'string'
            ) {
              const parsedOutputText = extractFirstJsonObject(
                content.output_text
              )
              if (parsedOutputText) return parsedOutputText
            }

            if (content?.value && typeof content.value === 'string') {
              const parsedValue = extractFirstJsonObject(content.value)
              if (parsedValue) return parsedValue
            }
          }
        }

        const outputText = extractOutputText(responseJson)
        return extractFirstJsonObject(outputText)
      }

      async function generateLocationFact(location, factType) {
        const normalizedFactType = normalizeFactType(factType)
        const vibeLabel = formatFactTypeLabel(normalizedFactType)

        const system = `You are helping power a conference web demo called Dynamic Fact Finder.

Return only valid JSON that matches the schema.
The audience is developers and curious people who like maps, math, computer science, and playful interfaces.
Keep the tone smart, crisp, lightly playful, and presentation-ready.
For Historical facts, be grounded and interesting.
For Spooky facts, be eerie but plausible.
For Fun facts, be delightful and surprising.`

        const user = `Generate one concise location fact card for ${location}.
Selected vibe: ${vibeLabel}.

Rules:
- headline should be 2 to 7 words
- fact should be 1 or 2 sentences, max 42 words
- rewardLabel should feel like a short achievement tag, max 3 words`

        const response = await postOpenAIJson({
          model: CONFIG.openaiModel || 'gpt-5.4-mini',
          store: false,
          input: [
            { role: 'system', content: system },
            { role: 'user', content: user }
          ],
          text: {
            format: {
              type: 'json_schema',
              name: 'location_fact_card',
              strict: true,
              schema: {
                type: 'object',
                properties: {
                  headline: { type: 'string' },
                  fact: { type: 'string' },
                  rewardLabel: { type: 'string' }
                },
                required: ['headline', 'fact', 'rewardLabel'],
                additionalProperties: false
              }
            }
          }
        })

        const parsed = extractStructuredObject(response)

        if (!parsed) {
          console.error('OpenAI raw fact response:', JSON.stringify(response, null, 2))
          throw new Error(
            'OpenAI returned a response, but the fact card JSON could not be read.'
          )
        }

        return {
          ok: true,
          location,
          factType: normalizedFactType,
          headline: parsed.headline || 'Generated fact',
          fact: parsed.fact || '',
          rewardLabel: parsed.rewardLabel || 'Unlocked'
        }
      }

      function escapeXml(value = '') {
        return String(value)
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;')
          .replaceAll("'", '&#39;')
      }

      function shorten(value = '', max = 44) {
        const text = String(value || '').trim()
        if (text.length <= max) return text
        return `${text.slice(0, max - 1).trim()}…`
      }

      function lonLatToTileFraction(lon, lat, z) {
        const latRad = (lat * Math.PI) / 180
        const n = 2 ** z
        const tileX = ((lon + 180) / 360) * n
        const tileY =
          ((1 - Math.log(Math.tan(latRad) + 1 / Math.cos(latRad)) / Math.PI) /
            2) *
          n
        return { tileX, tileY }
      }

      function wrapTileX(x, z) {
        const n = 2 ** z
        return ((x % n) + n) % n
      }

      function clampTileY(y, z) {
        const max = 2 ** z - 1
        return Math.max(0, Math.min(max, y))
      }

      async function fetchTileDataUrl(style, z, x, y) {
        const safeX = wrapTileX(x, z)
        const safeY = clampTileY(y, z)

        const url = `https://static-map-tiles-api.arcgis.com/arcgis/rest/services/static-basemap-tiles-service/v1/${style}/static/tile/${z}/${safeY}/${safeX}?token=${encodeURIComponent(
          CONFIG.arcgisApiKey
        )}`

        const response = await fetch(url)
        if (!response.ok) {
          throw new Error(`Tile request failed with ${response.status}`)
        }

        const blob = await response.blob()
        return await new Promise((resolve, reject) => {
          const reader = new FileReader()
          reader.onloadend = () => resolve(reader.result)
          reader.onerror = reject
          reader.readAsDataURL(blob)
        })
      }

      async function fetchCenteredBasemapSnapshot(mapLocation, factType = 'fun') {
        if (
          !mapLocation ||
          typeof mapLocation.x !== 'number' ||
          typeof mapLocation.y !== 'number'
        ) {
          return null
        }

        const TILE_SIZE = 512
        const lon = mapLocation.x
        const lat = mapLocation.y
        const z = 13
        const style = getStaticStyleForFactType(factType)

        const { tileX, tileY } = lonLatToTileFraction(lon, lat, z)
        const centerTileX = Math.floor(tileX)
        const centerTileY = Math.floor(tileY)

        const startTileX = centerTileX - 1
        const startTileY = centerTileY - 1

        const tiles = await Promise.all(
          Array.from({ length: 9 }, (_, idx) => {
            const row = Math.floor(idx / 3)
            const col = idx % 3
            return fetchTileDataUrl(
              style,
              z,
              startTileX + col,
              startTileY + row
            ).then(imageUrl => ({
              imageUrl,
              x: col * TILE_SIZE,
              y: row * TILE_SIZE
            }))
          })
        )

        const centerLocalX = (tileX - startTileX) * TILE_SIZE
        const centerLocalY = (tileY - startTileY) * TILE_SIZE

        const cropLeft = centerLocalX - TILE_SIZE / 2
        const cropTop = centerLocalY - TILE_SIZE / 2

        const imageTags = tiles
          .map(
            tile => `<image href="${tile.imageUrl}" x="${tile.x - cropLeft}" y="${
              tile.y - cropTop
            }" width="${TILE_SIZE}" height="${TILE_SIZE}" preserveAspectRatio="none" />`
          )
          .join('')

        const svg = `
          <svg xmlns="http://www.w3.org/2000/svg" width="${TILE_SIZE}" height="${TILE_SIZE}" viewBox="0 0 ${TILE_SIZE} ${TILE_SIZE}">
            <rect width="${TILE_SIZE}" height="${TILE_SIZE}" fill="#eef4ff" />
            ${imageTags}
          </svg>`

        return {
          imageUrl: `data:image/svg+xml;charset=utf-8,${encodeURIComponent(svg)}`,
          style,
          zoom: z,
          centered: true
        }
      }

      async function loadMapSnapshotForCurrentDiscovery() {
        if (!getMapUnlocked() || !currentDiscovery?.mapLocation) {
          renderMapUnlockState()
          return
        }

        isLoadingMapSnapshot = true
        latestMapSnapshot = null
        updateActionButtons()
        renderMapUnlockState()

        try {
          const snapshot = await fetchCenteredBasemapSnapshot(
            currentDiscovery.mapLocation,
            currentDiscovery.factType
          )

          if (snapshot?.imageUrl) {
            renderMapSnapshot(snapshot)
            mapRevealTextEl.textContent =
              'A centered basemap snapshot now anchors the location.'
          } else {
            renderMapSnapshot(null)
            mapRevealTextEl.textContent =
              'Map snapshot is unlocked, but could not load for this place right now.'
          }
        } catch (err) {
          console.error(err)
          renderMapSnapshot(null)
          mapRevealTextEl.textContent =
            'Map snapshot is unlocked, but could not load for this place right now.'
        } finally {
          isLoadingMapSnapshot = false
          updateActionButtons()
        }
      }

      async function generateFact() {
        let location = locationInput.value.trim()

        if (!location) {
          statusEl.textContent = 'Please choose a place first.'
          return
        }

        if (isGeneratingPostcard || isLoadingMapSnapshot) return

        clearPostcard()
        latestMapSnapshot = null
        renderMapSnapshot(null)
        statusEl.textContent = 'Resolving place...'
        resultEl.classList.add('hidden')

        try {
          let mapLocation = null

          if (selectedSuggestion && selectedSuggestion.text === location) {
            const resolved = await resolveSelectedPlace()

            if (resolved?.found && resolved?.label) {
              location = resolved.label
              locationInput.value = resolved.label
              mapLocation = resolved.location || null
              saveResolvedPlace(resolved.label, resolved.location || null)
              statusEl.textContent = `Resolved place: ${resolved.label}`
            } else {
              saveResolvedPlace(location, null)
            }
          } else if (
            lastResolvedLabel &&
            location === lastResolvedLabel &&
            lastResolvedLocation
          ) {
            mapLocation = lastResolvedLocation
          } else {
            saveResolvedPlace(location, null)
          }

          statusEl.textContent = 'Generating fact...'

          const data = await generateLocationFact(location, selectedFactType)

          currentDiscovery = {
            location,
            factType: normalizeFactType(data.factType || selectedFactType),
            headline: data.headline || 'Generated fact',
            fact: data.fact || '',
            rewardLabel: data.rewardLabel || 'Unlocked',
            mapLocation: mapLocation || null
          }

          discoveriesHistory.push(currentDiscovery)
          discoveriesHistory = discoveriesHistory.slice(-12)

          factsDiscovered += 1
          if (factsDiscovered >= 3) postcardUnlocked = true

          headlineEl.textContent = currentDiscovery.headline
          factTextEl.textContent = currentDiscovery.fact
          rewardPillEl.textContent = currentDiscovery.rewardLabel
          resolvedPlaceEl.textContent = location
          factTypeValueEl.textContent = formatFactTypeLabel(
            currentDiscovery.factType
          )
          progressCueEl.textContent = getProgressCue()

          saveProgress()
          resultEl.classList.remove('hidden')
          syncProgressUI()

          if (getMapUnlocked() && currentDiscovery.mapLocation) {
            await loadMapSnapshotForCurrentDiscovery()
          } else {
            renderMapUnlockState()
          }

          if (factsDiscovered === 2) {
            statusEl.textContent = 'Fact generated. Map snapshot unlocked!'
          } else if (factsDiscovered === 3) {
            statusEl.textContent = 'Fact generated. Postcards unlocked!'
          } else {
            statusEl.textContent = 'Fact generated.'
          }
        } catch (err) {
          console.error(err)
          statusEl.textContent = `Error: ${err.message}`
        }
      }

