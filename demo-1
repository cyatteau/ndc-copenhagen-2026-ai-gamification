        statusEl.textContent = 'Getting your location...'

        navigator.geolocation.getCurrentPosition(
          async position => {
            try {
              const lat = position.coords.latitude
              const lon = position.coords.longitude
              lastKnownCoords = { lat, lon }

              statusEl.textContent = 'Resolving current location...'

              const data = await reverseGeocode(lat, lon)

              if (data?.label) {
                locationInput.value = data.label
                selectedSuggestion = null
                saveResolvedPlace(data.label, data.location || { x: lon, y: lat })
                statusEl.textContent = `Using current location: ${data.label}`
